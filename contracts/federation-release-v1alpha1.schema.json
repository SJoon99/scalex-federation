{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scalex.io/schemas/federation-release-v1alpha1.schema.json",
  "title": "Federation release descriptor v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "namespace",
    "state",
    "renderer",
    "source",
    "values",
    "promotion"
  ],
  "properties": {
    "name": { "$ref": "#/$defs/dnsLabel" },
    "namespace": {
      "type": "string",
      "pattern": "^scalex-[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "state": { "enum": ["active", "disabled"] },
    "disabledReason": { "type": "string", "minLength": 1 },
    "renderer": { "const": "helm/v1" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repoURL", "path", "revision"],
      "properties": {
        "repoURL": {
          "type": "string",
          "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+\\.git$"
        },
        "path": { "$ref": "#/$defs/chartPath" },
        "revision": {
          "type": "string",
          "pattern": "^(?!0{40}$)[0-9a-f]{40}$"
        }
      }
    },
    "values": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^releases/[a-z0-9]([-a-z0-9]*[a-z0-9])?/values\\.yaml$"
        }
      }
    },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": { "mode": { "enum": ["tracked", "pinned"] } }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "state": { "const": "disabled" } } },
      "then": { "required": ["disabledReason"] },
      "else": { "not": { "required": ["disabledReason"] } }
    }
  ],
  "$defs": {
    "dnsLabel": {
      "type": "string",
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "chartPath": {
      "type": "string",
      "pattern": "^(chart|charts/[a-z0-9]([-a-z0-9]*[a-z0-9])?)$"
    }
  }
}
