{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scalex.io/schemas/federation-release-v1alpha1.schema.json",
  "title": "FederationRelease v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "name",
    "environment",
    "namespace",
    "renderer",
    "source",
    "values",
    "dependencies",
    "policy",
    "promotion"
  ],
  "properties": {
    "apiVersion": { "const": "scalex.io/v1alpha1" },
    "kind": { "const": "FederationRelease" },
    "name": { "$ref": "#/$defs/dnsLabel" },
    "environment": { "$ref": "#/$defs/dnsLabel" },
    "namespace": { "type": "string", "pattern": "^scalex-[a-z0-9]([-a-z0-9]*[a-z0-9])?$" },
    "renderer": { "const": "helm/v1" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repoURL", "path", "revision"],
      "properties": {
        "repoURL": { "type": "string", "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+\\.git$" },
        "path": { "$ref": "#/$defs/chartPath" },
        "revision": { "type": "string", "pattern": "^(?!0{40}$)[0-9a-f]{40}$" }
      }
    },
    "values": { "$ref": "#/$defs/valuesPathObject" },
    "dependencies": { "$ref": "#/$defs/dependenciesPathObject" },
    "policy": { "$ref": "#/$defs/policyPathObject" },
    "promotion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": { "mode": { "enum": ["tracked", "pinned"] } }
    }
  },
  "$defs": {
    "dnsLabel": { "type": "string", "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$" },
    "chartPath": { "type": "string", "pattern": "^(chart|charts/[a-z0-9]([-a-z0-9]*[a-z0-9])?)$" },
    "valuesPathObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": { "path": { "type": "string", "pattern": "^releases/[a-z0-9]([-a-z0-9]*[a-z0-9])?/[a-z0-9]([-a-z0-9]*[a-z0-9])?/values\\.yaml$" } }
    },
    "dependenciesPathObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": { "path": { "type": "string", "pattern": "^releases/[a-z0-9]([-a-z0-9]*[a-z0-9])?/[a-z0-9]([-a-z0-9]*[a-z0-9])?/dependencies$" } }
    },
    "policyPathObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": { "path": { "type": "string", "pattern": "^releases/[a-z0-9]([-a-z0-9]*[a-z0-9])?/[a-z0-9]([-a-z0-9]*[a-z0-9])?/policy$" } }
    }
  }
}
